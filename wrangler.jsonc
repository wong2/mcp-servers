{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "mcp-servers",
  "main": "./src/index.ts",
  "compatibility_date": "2026-05-17",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "routes": [
    {
      "pattern": "gateway.mcpservers.org",
      "custom_domain": true
    }
  ]
}
